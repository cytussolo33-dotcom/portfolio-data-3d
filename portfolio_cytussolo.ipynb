<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cytussolo | Spatial Data Analyst</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
:root {
  --bg:#0a0e1a;
  --card:#111827;
  --accent:#00ff9d;
  --text:#e5e7eb;
}

* {margin:0; padding:0; box-sizing:border-box;}

body {
  font-family:'Inter', sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* NAV */
nav {
  display:flex;
  justify-content:space-between;
  padding:20px 40px;
  position:sticky;
  top:0;
  background:rgba(10,14,26,0.7);
  backdrop-filter:blur(12px);
  z-index:10;
}

/* HERO */
.hero {
  text-align:center;
  padding:120px 20px;
}

.hero h1 {
  font-size:3rem;
}

.hero span {
  color:var(--accent);
}

.btn {
  display:inline-block;
  margin-top:20px;
  padding:12px 20px;
  background:var(--accent);
  color:black;
  border-radius:8px;
  text-decoration:none;
  font-weight:600;
  transition:0.3s;
}

.btn:hover {
  transform:scale(1.05);
}

/* SECTIONS */
.section {
  max-width:1100px;
  margin:auto;
  padding:60px 20px;
}

.grid {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(300px,1fr));
  gap:25px;
}

.card {
  background:var(--card);
  padding:20px;
  border-radius:16px;
  transition:0.4s;
  position:relative;
  overflow:hidden;
}

.card:hover {
  transform:translateY(-8px);
}

.card img {
  width:100%;
  border-radius:10px;
  margin-bottom:10px;
}

.card .actions {
  margin-top:10px;
}

.card .actions a {
  margin-right:10px;
}

/* SKILLS */
.skills span {
  display:inline-block;
  margin:6px;
  padding:8px 12px;
  background:#1f2937;
  border-radius:8px;
  transition:0.3s;
}

.skills span:hover {
  background:var(--accent);
  color:black;
}

/* FOOTER */
footer {
  text-align:center;
  padding:40px;
  color:#888;
}

/* ANIMAÇÃO */
.fade {
  opacity:0;
  transform:translateY(30px);
  transition:0.6s;
}

.fade.show {
  opacity:1;
  transform:translateY(0);
}
</style>
</head>

<body>

<nav>
  <h3>Cytussolo</h3>
</nav>

<section class="hero fade">
  <h1>👨‍💻 Dados <span>Espaciais & 3D</span></h1>
  <p>Projetos reais com Python, visualização e modelagem</p>
  <a class="btn" href="#projetos">Ver Projetos</a>
</section>

<section id="projetos" class="section">
  <h2>🚀 Projetos</h2>

  <div class="grid">

    <div class="card fade">
      <h3>🌍 Geoespacial</h3>
      <img src="mapa_brasil.png">
      <p>Análise de população com GeoPandas.</p>
      <div class="actions">
        <a class="btn" href="mapa_brasil.png" target="_blank">Abrir</a>
      </div>
    </div>

    <div class="card fade">
      <h3>🧊 Terreno 3D</h3>
      <img src="terrain.png">
      <p>Modelagem 3D exportável para Blender.</p>
      <div class="actions">
        <a class="btn" href="terrain_model.obj">Download</a>
      </div>
    </div>

    <div class="card fade">
      <h3>📊 Dashboard</h3>
      <img src="dashboard.png">
      <p>Visualização de dados e insights.</p>
      <div class="actions">
        <a class="btn" href="dados_vendas.csv">Dados</a>
      </div>
    </div>

  </div>
</section>

<section class="section">
  <h2>🧠 Skills</h2>
  <div class="skills">
    <span>Python</span>
    <span>GeoPandas</span>
    <span>Data Analysis</span>
    <span>3D Modeling</span>
    <span>Matplotlib</span>
    <span>Pandas</span>
  </div>
</section>

<section class="section">
  <h2>📬 Contato</h2>
  <p>Email: seuemail@email.com</p>
  <p>GitHub: github.com/seuusuario</p>
</section>

<footer>
  <p>© 2026 Cytussolo</p>
</footer>

<script>
// animação ao scroll
const elements = document.querySelectorAll('.fade');

const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      entry.target.classList.add('show');
    }
  });
});

elements.forEach(el => observer.observe(el));
</script>

</body>
</html>
